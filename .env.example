# Copy to .env and fill in real values before running docker compose or tofu apply

# Alpha Vantage (free at alphavantage.co — 25 calls/day)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Telegram (get from @BotFather and @userinfobot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Neon PostgreSQL (free at neon.tech — run infra/schema.sql first)
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Trading
ACCOUNT_BALANCE=10000
RISK_PERCENT=1.5
POLL_INTERVAL_SECONDS=3480

# Logging
LOG_LEVEL=INFO
